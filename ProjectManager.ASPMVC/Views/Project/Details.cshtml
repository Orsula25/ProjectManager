@using ProjectManager.ASPMVC.Handlers
@inject UserSessionManager session
@model ProjectManager.ASPMVC.Models.Project.ProjectDetailsModel

@{
    ViewData["Title"] = Model.Project.Name;
    ViewData["EmployeeName"] = $"{session.FirstName} {session.LastName}";
    ViewData["IsManager"] = session.IsManager;
}

<h1>@Model.Project.Name</h1>
<p class="text-muted">Créé le @Model.Project.CreationDate.ToString("dd/MM/yyyy")</p>
<p>@Model.Project.Description</p>

@if (session.IsManager)
{
    <form asp-action="UpdateDescription" asp-route-id="@Model.Project.ProjectId" method="post">
        <input type="text" name="description" class="form-control" value="@Model.Project.Description" />
        <button type="submit" class="btn btn-outline-primary mt-2">Modifier la description</button>
    </form>
}

<hr />

<h4>Équipe du projet</h4>

@foreach (var member in Model.Members)
{
    <div class="d-flex align-items-center gap-2 mb-2">
        <span>@member.FirstName @member.LastName</span>
        @if (member.IsProjectManager)
        {
            <span class="badge bg-primary">Chef de projet</span>
        }
        @if (session.IsManager && !member.IsProjectManager)
        {
            <form asp-action="RemoveMember" method="post" class="d-inline">
                <input type="hidden" name="projectId" value="@Model.Project.ProjectId" />
                <input type="hidden" name="employeeId" value="@member.EmployeeId" />
                <button type="submit" class="btn btn-sm btn-outline-danger">Retirer</button>
            </form>
        }
    </div>
}

@if (session.IsManager && Model.FreeEmployees != null && Model.FreeEmployees.Any())
{
    <form asp-action="AddMember" method="post" class="mt-3">
        <input type="hidden" name="projectId" value="@Model.Project.ProjectId" />
        <select name="employeeId" class="form-select w-auto d-inline">
            @foreach (var emp in Model.FreeEmployees)
            {
                <option value="@emp.EmployeeId">@emp.FirstName @emp.LastName</option>
            }
        </select>
        <button type="submit" class="btn btn-primary">Ajouter</button>
    </form>
}

<hr />

<h4>Messages</h4>

<a asp-controller="Post" asp-action="Create" asp-route-projectId="@Model.Project.ProjectId" class="btn btn-primary mb-3">
    Nouveau post
</a>

@if (Model.Posts != null && Model.Posts.Any())
{
    @foreach (var post in Model.Posts)
    {
        <div class="border-bottom mb-3 pb-3">
            <h6>@post.Subject</h6>
            <p>@post.Content</p>
            <small class="text-muted">@post.SendDate.ToString("dd/MM/yyyy HH:mm")</small>
        </div>
    }
}
else
{
    <p class="text-muted">Aucun message pour ce projet.</p>
}