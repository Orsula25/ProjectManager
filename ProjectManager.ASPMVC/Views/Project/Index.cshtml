@using ProjectManager.ASPMVC.Handlers
@inject UserSessionManager session
@model IEnumerable<ProjectManager.BLL.Entities.Project>

@{
    ViewData["Title"] = "Liste des projets";
    ViewData["EmployeeName"] = $"{session.FirstName} {session.LastName}";
    ViewData["IsManager"] = session.IsManager;
    ViewData["UnreadPostsCount"] = 3; // À remplacer par le vrai compteur
}

<div class="row">
    <div class="col-12">
        <h2 class="mb-4">Vos projets</h2>
    </div>
</div>

<div class="row">
    @foreach (var project in Model)
    {
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 project-card">
                <div class="card-body">
                    <h5 class="card-title">@project.Name</h5>
                    <p class="card-text text-muted project-description">@project.Description</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted project-stats">
                            @if (project.Members != null)
                            {
                                @($"{project.Members.Count()} Membres")
                            }
                            else
                            {
                                @("0 Membres")
                            }
                        </small>
                        <a asp-action="Details" asp-route-id="@project.ProjectId" 
                           class="btn btn-primary">Accéder</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <h3 class="text-muted">Aucun projet trouvé</h3>
        <p class="text-muted">Vous n'êtes actuellement affecté à aucun projet.</p>
    </div>
}
