@using ProjectManager.ASPMVC.Handlers
@inject UserSessionManager session

@{
    ViewData["Title"] = "Créer un post";
    ViewData["EmployeeName"] = $"{session.FirstName} {session.LastName}";
    ViewData["IsManager"] = session.IsManager;
}

<div class="row">
    <div class="col-12">
        <h2 class="mb-4">Rédiger un nouveau post</h2>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <input type="hidden" name="projectId" value="@ViewData["ProjectId"]" />
                    
                    <div class="mb-3">
                        <label for="subject" class="form-label">Sujet</label>
                        <input type="text" class="form-control" id="subject" name="subject" required />
                    </div>
                    
                    <div class="mb-3">
                        <label for="content" class="form-label">Contenu</label>
                        <textarea class="form-control" id="content" name="content" rows="6" required></textarea>
                    </div>
                    
                    <div class="d-flex justify-content-between">
                        <a asp-controller="Project" asp-action="Details" asp-route-id="@ViewData["ProjectId"]" 
                           class="btn btn-secondary">Annuler</a>
                        <button type="submit" class="btn btn-primary">Publier</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
