<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Project Manager</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>
    <header class="bg-primary text-white py-3">
        <div class="container">
            <div class="row align-items-center">
                <div class="col">
                    <h1 class="h3 mb-0">Bienvenue, @(ViewData["EmployeeName"] ?? "Utilisateur")</h1>
                </div>
                <div class="col-auto">
                    @if (ViewData["EmployeeId"] != null)
                    {
                        <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                            <button type="submit" class="btn btn-outline-light">Déconnexion</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </header>

    <nav class="bg-light border-bottom">
        <div class="container">
            <ul class="nav nav-pills py-3">
                @if (ViewData["IsManager"] as bool? == true)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Project" asp-action="Create">
                            <i class="bi bi-plus-circle"></i> Créer Projet
                        </a>
                    </li>
                }
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Project" asp-action="Index">Projets</a>
                </li>
                <li class="nav-item position-relative">
                    <a class="nav-link" asp-controller="Post" asp-action="Index">
                        Posts
                        @if (ViewData["UnreadPostsCount"] as int? > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                @(ViewData["UnreadPostsCount"])
                            </span>
                        }
                    </a>
                </li>
            </ul>
        </div>
    </nav>

    <main class="container py-4">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
